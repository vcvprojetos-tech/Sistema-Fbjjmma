generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTENTICAÇÃO E PERFIS ───────────────────────────────────────────────────

enum UserRole {
  PRESIDENTE
  COORDENADOR_GERAL
  COORDENADOR_TATAME
  ATLETA
  CUSTOM
}

model User {
  id            String     @id @default(cuid())
  name          String
  cpf           String     @unique
  email         String     @unique
  emailVerified DateTime?
  password      String
  phone         String?
  role          UserRole   @default(ATLETA)
  customRoleId  String?
  customRole    CustomRole? @relation(fields: [customRoleId], references: [id])
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  athlete           Athlete?
  auditLogs         AuditLog[]
  eventCoordinators EventCoordinator[]
  tatameOperations  TatameOperation[]

  @@map("users")
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  createdAt   DateTime @default(now())
  users       User[]

  @@map("custom_roles")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ATLETAS ─────────────────────────────────────────────────────────────────

enum Sex {
  MASCULINO
  FEMININO
}

enum Belt {
  BRANCA
  AMARELA_LARANJA_VERDE
  AZUL
  ROXA
  MARROM
  PRETA
}

model Athlete {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo        String?
  birthDate    DateTime
  sex          Sex
  belt         Belt     @default(BRANCA)
  weight       Float
  teamId       String?
  team         Team?    @relation(fields: [teamId], references: [id])
  professor    String?
  street       String?
  city         String?
  state        String?
  zipCode      String?
  isAffiliated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamHistory   AthleteTeamHistory[]
  registrations Registration[]

  @@map("athletes")
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  athletes      Athlete[]
  teamHistory   AthleteTeamHistory[]
  registrations Registration[]

  @@map("teams")
}

model AthleteTeamHistory {
  id        String    @id @default(cuid())
  athleteId String
  athlete   Athlete   @relation(fields: [athleteId], references: [id])
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id])
  startDate DateTime  @default(now())
  endDate   DateTime?

  @@map("athlete_team_history")
}

// ─── TABELAS DE PESO ─────────────────────────────────────────────────────────

enum AgeGroup {
  PRE_MIRIM
  MIRIM
  INFANTIL_A
  INFANTIL_B
  INFANTO_JUVENIL_A
  INFANTO_JUVENIL_B
  JUVENIL
  ADULTO
  MASTER_1
  MASTER_2
  MASTER_3
  MASTER_4
  MASTER_5
  MASTER_6
}

model WeightTable {
  id        String           @id @default(cuid())
  name      String           @unique
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  categories WeightCategory[]
  events     Event[]

  @@map("weight_tables")
}

model WeightCategory {
  id        String      @id @default(cuid())
  tableId   String
  table     WeightTable @relation(fields: [tableId], references: [id])
  ageGroup  AgeGroup
  sex       Sex
  name      String
  maxWeight Float
  order     Int

  registrations Registration[]
  brackets      Bracket[]

  @@unique([tableId, ageGroup, sex, name])
  @@map("weight_categories")
}

// ─── EVENTOS ─────────────────────────────────────────────────────────────────

enum EventStatus {
  RASCUNHO
  INSCRICOES_ABERTAS
  INSCRICOES_ENCERRADAS
  EM_ANDAMENTO
  ENCERRADO
}

model EventType {
  id     String  @id @default(cuid())
  name   String  @unique
  events Event[]

  @@map("event_types")
}

model Event {
  id                   String      @id @default(cuid())
  name                 String
  typeId               String
  type                 EventType   @relation(fields: [typeId], references: [id])
  state                String
  city                 String
  location             String
  date                 DateTime
  registrationDeadline DateTime
  correctionDeadline   DateTime
  paymentDeadline      DateTime
  checkinRelease       DateTime
  bracketRelease       DateTime
  weightTableId        String
  weightTable          WeightTable @relation(fields: [weightTableId], references: [id])
  value                Float       @default(0)
  hasAbsolute          Boolean     @default(false)
  absoluteValue        Float?
  registrationOpen     Boolean     @default(false)
  isVisible            Boolean     @default(false)
  banner               String?
  schedule             String?
  pesoDoc              String?
  about                String?
  paymentInfo          String?
  prize                String?
  weighInInfo          String?
  imageRights          String?
  physicalIntegrity    String?
  status               EventStatus @default(RASCUNHO)
  deletedAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  categoryValues EventCategoryValue[]
  registrations  Registration[]
  tatames        Tatame[]
  brackets       Bracket[]
  coordinators   EventCoordinator[]

  @@map("events")
}

model EventCategoryValue {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sex           Sex
  ageGroup      AgeGroup
  value         Float    @default(0)
  hasAbsolute   Boolean  @default(false)
  absoluteValue Float?

  @@unique([eventId, sex, ageGroup])
  @@map("event_category_values")
}

// ─── INSCRIÇÕES ──────────────────────────────────────────────────────────────

enum RegistrationStatus {
  PENDENTE
  APROVADO
  CANCELADO
}

enum PaymentMethod {
  PIX
  CARTAO
  DINHEIRO
  ISENTO
}

model Registration {
  id               String             @id @default(cuid())
  eventId          String
  event            Event              @relation(fields: [eventId], references: [id])
  athleteId        String?
  athlete          Athlete?           @relation(fields: [athleteId], references: [id])
  guestName        String?
  teamId           String?
  team             Team?              @relation(fields: [teamId], references: [id])
  professor        String?
  sex              Sex
  ageGroup         AgeGroup
  belt             Belt
  weightCategoryId String
  weightCategory   WeightCategory     @relation(fields: [weightCategoryId], references: [id])
  isAbsolute       Boolean            @default(false)
  status           RegistrationStatus @default(PENDENTE)
  paymentMethod    PaymentMethod?
  paymentProof     String?
  observation      String?
  medal            String?
  teamPoints       Boolean            @default(true)
  awarded          Boolean            @default(false)
  prizePix         String?
  affiliated       Boolean            @default(false)
  pointDiff        Boolean            @default(false)
  registeredAt     DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  bracketPositions BracketPosition[]

  @@unique([eventId, athleteId, isAbsolute])
  @@map("registrations")
}

// ─── TATAMES E COORDENADORES ─────────────────────────────────────────────────

model Tatame {
  id                String    @id @default(cuid())
  eventId           String
  event             Event     @relation(fields: [eventId], references: [id])
  name              String
  pin               String
  isActive          Boolean   @default(false)
  panelBracketIds   String[]  @default([])
  panelUpdatedAt    DateTime?
  createdAt         DateTime  @default(now())

  brackets   Bracket[]
  operations TatameOperation[]

  @@unique([eventId, name])
  @@map("tatames")
}

model EventCoordinator {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@map("event_coordinators")
}

model TatameOperation {
  id             String    @id @default(cuid())
  tatameId       String
  tatame         Tatame    @relation(fields: [tatameId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  lastHeartbeat  DateTime?

  @@map("tatame_operations")
}

// ─── CHAVES ──────────────────────────────────────────────────────────────────

enum BracketStatus {
  PENDENTE
  DESIGNADA
  EM_ANDAMENTO
  FINALIZADA
  PREMIADA
}

model Bracket {
  id               String         @id @default(cuid())
  eventId          String
  event            Event          @relation(fields: [eventId], references: [id])
  tatameId         String?
  tatame           Tatame?        @relation(fields: [tatameId], references: [id])
  weightCategoryId String
  weightCategory   WeightCategory @relation(fields: [weightCategoryId], references: [id])
  belt             Belt
  isAbsolute       Boolean        @default(false)
  bracketNumber    Int
  status           BracketStatus  @default(PENDENTE)
  // Quando uma categoria tem > 16 atletas, é dividida em 2 sub-chaves com mesmo bracketGroupId.
  // Após ambas finalizarem, uma "grande final" (isGrandFinal=true) é criada automaticamente.
  bracketGroupId   String?
  isGrandFinal     Boolean        @default(false)
  startedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  positions BracketPosition[]
  matches   Match[]

  @@map("brackets")
}

model BracketPosition {
  id             String        @id @default(cuid())
  bracketId      String
  bracket        Bracket       @relation(fields: [bracketId], references: [id])
  position       Int
  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id])
  isEliminated   Boolean       @default(false)

  matchesAsP1 Match[] @relation("MatchPosition1")
  matchesAsP2 Match[] @relation("MatchPosition2")
  matchesWon  Match[] @relation("MatchWinner")

  @@unique([bracketId, position])
  @@map("bracket_positions")
}

enum WOType {
  PESO
  AUSENCIA
  DESCLASSIFICACAO
}

model Match {
  id          String           @id @default(cuid())
  bracketId   String
  bracket     Bracket          @relation(fields: [bracketId], references: [id])
  round       Int
  matchNumber Int
  position1Id String?
  position1   BracketPosition? @relation("MatchPosition1", fields: [position1Id], references: [id])
  position2Id String?
  position2   BracketPosition? @relation("MatchPosition2", fields: [position2Id], references: [id])
  winnerId    String?
  winner      BracketPosition? @relation("MatchWinner", fields: [winnerId], references: [id])
  isWO        Boolean          @default(false)
  woType      WOType?
  woWeight1   Float?
  woWeight2   Float?
  woReason    String?
  callTimes   Json?
  p1CheckedIn Boolean          @default(false)
  p2CheckedIn Boolean          @default(false)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime         @default(now())

  @@map("matches")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  module    String
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
